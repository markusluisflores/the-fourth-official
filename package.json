{
  "name": "the-fourth-official",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "ingest": "cross-env NODE_OPTIONS=\"--experimental-websocket --conditions=react-server\" tsx --env-file=.env.local scripts/ingest/index.ts",
